# Copy this file to .env.local and fill in the values from your Supabase
# project (Dashboard → Project Settings → API). The anon key is safe to expose
# in the browser — row-level security in the database is what protects data.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
